#!/usr/bin/env bash
# Blocks pushing commits that contain secrets or a blocked (e.g. corporate) email.
# Enable once per clone:  git config core.hooksPath .githooks
# The same checks run in CI (.github/workflows/ci.yml → guard) as a backstop.
set -euo pipefail

# Space-separated email domains that must never appear in commit metadata or files.
BLOCKED_EMAIL_DOMAINS="alibaba-inc.com"

# High-signal secret patterns (CI runs a fuller gitleaks scan on top of these).
SECRET_PATTERNS='-----BEGIN [A-Z ]*PRIVATE KEY-----|AKIA[0-9A-Z]{16}|gh[pousr]_[A-Za-z0-9]{20,}|xox[baprs]-[A-Za-z0-9-]{10,}|AIza[0-9A-Za-z_-]{30,}'

z40=0000000000000000000000000000000000000000
fail=0

while read -r _local_ref local_sha _remote_ref remote_sha; do
  [ "$local_sha" = "$z40" ] && continue                      # branch deletion
  if [ "$remote_sha" = "$z40" ]; then range="$local_sha"; else range="$remote_sha..$local_sha"; fi

  # 1) Blocked emails in commit author/committer metadata.
  emails="$(git log --format='%ae%n%ce' "$range" 2>/dev/null || true)"
  for dom in $BLOCKED_EMAIL_DOMAINS; do
    if printf '%s\n' "$emails" | grep -qiF "@$dom"; then
      echo "✖ pre-push: commit author/committer email at @$dom in $range" >&2
      fail=1
    fi
  done

  # 2) Secrets or blocked emails in the added/changed content. The guard files
  #    themselves define these patterns, so exclude them to avoid self-matching.
  patch="$(git log -p --no-color "$range" -- . ':!.githooks' ':!.github' 2>/dev/null || true)"
  added="$(printf '%s\n' "$patch" | grep '^+' || true)"
  if printf '%s\n' "$added" | grep -qEi -e "$SECRET_PATTERNS"; then
    echo "✖ pre-push: a secret-like token appears in the pushed diff." >&2
    fail=1
  fi
  for dom in $BLOCKED_EMAIL_DOMAINS; do
    if printf '%s\n' "$added" | grep -qiF "@$dom"; then
      echo "✖ pre-push: blocked email @$dom appears in the pushed diff." >&2
      fail=1
    fi
  done
done

if [ "$fail" -ne 0 ]; then
  echo "" >&2
  echo "Push aborted by .githooks/pre-push. Fix the commit(s) above (amend/rebase" >&2
  echo "to correct the email or remove the secret) and try again." >&2
  exit 1
fi
